{
  "name": "poolscore",
  "version": "2.0.0",
  "description": "A pool billard scoretracker",
  "homepage": "https://poolscore.butz.st",
  "private": true,
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.0",
    "@mui/icons-material": "^6.4.8",
    "@mui/material": "^6.4.8",
    "@mui/x-date-pickers": "^7.28.0",
    "@types/react": "^19.0.12",
    "@types/react-dom": "^19.0.4",
    "dayjs": "^1.11.13",
    "dotenv-cli": "^11.0.0",
    "firebase": "^11.5.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-firebase-hooks": "^5.1.1",
    "react-router": "^7.5.0",
    "react-scripts": "5.0.1",
    "typescript": "^4.9.5",
    "web-vitals": "^4.2.4",
    "workbox-core": "^7.3.0",
    "workbox-expiration": "^7.3.0",
    "workbox-precaching": "^7.3.0",
    "workbox-routing": "^7.3.0",
    "workbox-strategies": "^7.3.0"
  },
  "scripts": {
    "start": "npx firebase-tools emulators:exec --ui --only=\"auth,firestore\" \"react-scripts start\" --import ./emulator_data",
    "build": "react-scripts build",
    "build:staging": "dotenv -e .env.staging npm run build",
    "deploy:production": "npm run build && npx firebase-tools deploy --only 'auth,hosting,firestore'",
    "deploy:staging": "npm run build:staging && npx firebase-tools deploy --only 'auth,hosting,firestore' -P staging",
    "use:staging": "npx firebase-tools use staging",
    "use:production": "npx firebase-tools use default",
    "update-emulator-data": "npx firebase-tools emulators:export --only \"auth,firestore\" ./emulator_data",
    "test": "react-scripts test",
    "lint": "eslint src/",
    "eject": "react-scripts eject"
  },
  "browserslist": {
    "production": [
      ">0.1%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "eslint-config-airbnb": "^19.0.4",
    "eslint-config-airbnb-typescript": "^18.0.0",
    "firebase-tools": "^13.35.1"
  }
}
